includes:
    - vendor/larastan/larastan/extension.neon

parameters:

    paths:
        - app/
        - bootstrap/
        - config/
        - database/
        - routes/

    # Level 9 is the highest level
    level: 5

    ignoreErrors:
        - '#Unsafe usage of new static\(\).#'

    excludePaths:
        - ./routes/console.php
